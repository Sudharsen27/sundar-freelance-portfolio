# Local: copy to `.env.local` and fill in values.
# Production (Vercel): add the same keys in Project → Settings → Environment Variables, then redeploy.
# Gmail App Password: Google Account → Security → 2-Step Verification → App passwords (no spaces in SMTP_PASS)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=hello.sundardigital@gmail.com
SMTP_PASS=your-16-char-app-password-here
CONTACT_TO_EMAIL=hello.sundardigital@gmail.com
CONTACT_FROM_EMAIL=hello.sundardigital@gmail.com

# Local dev: http://localhost:3000
# Production (Vercel): https://www.sundardigital.in
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=916382519651
NEXT_PUBLIC_FIVERR_URL=https://www.fiverr.com/
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/sundar-lingam

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-M1JWMJW2KG
